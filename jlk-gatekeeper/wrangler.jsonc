{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "mohn-gatekeeper",
  "main": "src/index.ts",
  "compatibility_date": "2026-03-19",
  "compatibility_flags": ["nodejs_compat"],
  "vars": {
    "TMDB_API_TOKEN": "",
    "FRONTEND_URL": "",
    "BETTER_AUTH_URL": "",
    "BETTER_AUTH_SECRET": "",
    "GOOGLE_CLIENT_ID": "",
    "GOOGLE_CLIENT_SECRET": "",
  },
  "hyperdrive": [
    {
      "binding": "HYPERDRIVE",
      "id": "04aed4fb7de64b8f95abae8ba8c50018",
      "localConnectionString": "postgres://user:password@localhost:5432/better_auth",
    },
  ],
