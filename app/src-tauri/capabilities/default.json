{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:allow-set-fullscreen",
    "core:webview:allow-create-webview-window",
    "core:window:allow-close",
    "opener:default",
    "updater:default",
    "process:default",
    "libmpv:default",
    "oauth:allow-start",
    "oauth:allow-cancel"
  ]
}
