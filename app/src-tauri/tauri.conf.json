{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Mohn",
  "version": "0.1.0",
  "identifier": "com.mohn.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "bun run dev",
    "beforeBuildCommand": "bun run build"
  },
  "app": {
    "windows": [
      {
        "title": "Mohn",
        "width": 1280,
        "height": 800,
        "minWidth": 800,
        "minHeight": 540,
        "transparent": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["mohn"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "nsis",
    "publisher": "Cuerillius",
    "homepage": "https://mohn.app",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": ["lib/**/*"],
    "windows": {
      "nsis": {
        "headerImage": "installer/nsis-header.bmp",
        "sidebarImage": "installer/nsis-sidebar.bmp",
        "installerIcon": "icons/icon.ico"
      }
    }
  }
}
