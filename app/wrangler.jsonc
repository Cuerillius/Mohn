{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "mohn-web",
  "compatibility_date": "2026-06-17",
  "assets": {
    "directory": "./dist",
    "not_found_handling": "single-page-application"
  },
  // Runtime vars are set via GitHub Actions → wrangler deploy --var
  // Build-time VITE_* vars are injected as env vars during CI build
  "vars": {}
}
